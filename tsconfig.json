{
  "compilerOptions": {
    "module": "ESNext",
    "target": "es2020",
    "types": ["node"],
    "lib": ["es2020", "dom"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "sourceMap": true,
    "outDir": "dist",
    "paths": {
      "@/*": ["./bin/*"]
    },
    "typeRoots": ["./types", "./node_modules/@types"]
  },
  "include": ["bin/**/*", "types/**/*"]
}
